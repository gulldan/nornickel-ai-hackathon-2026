!ml-services/diagram-parser-service/pyproject.toml
!ml-services/diagram-parser-service/uv.lock
!ml-services/diagram-parser-service/diagram_parser_service/
!ml-services/diagram-parser-service/diagram_parser_service/**
**/target
**/.git
**/.DS_Store
