# Template for infra/.env. `make up` creates infra/.env automatically and fills
# the required local secrets when they are blank.
# Most infra URLs are wired in docker-compose.yml; this file is mainly for
# secrets, host-port overrides, and optional model endpoint overrides.

LOG_LEVEL=info
WORKER_CONCURRENCY=4

# Host ports (change if something already runs on these). Internal datastores
# (postgres/valkey/qdrant/opensearch) are NOT published — reach them via
# `docker compose exec`. The API gateway, frontend, and loopback-only local S3
# endpoint are the normal host entrypoints for local browser testing.
HTTP_PORT=8080
FRONTEND_PORT=5173
# Empty FRONTEND_PUBLIC_API keeps WebSocket/API traffic same-origin through the
# frontend nginx proxy. Set it only when the browser must connect elsewhere.
FRONTEND_PUBLIC_API=
RABBITMQ_UI_PORT=15672
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Auth / seeded admin. `make up` fills these before the first compose run.
# ВАЖНО: JWT_SECRET должен быть сильным (32+ случайных байта). `make up`
# генерирует его автоматически; auth и main-service откажутся стартовать без
# JWT_SECRET или на старом небезопасном значении 'dev-secret-change-me'.
JWT_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Публичный стенд: саморегистрация из интернета закрыта по умолчанию. true →
# POST /register принимается только с валидным admin-токеном (создание юзеров
# из админки работает). Ставьте false только для локального dev/e2e-контура.
REGISTRATION_ADMIN_ONLY=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
RABBITMQ_USER=rag
RABBITMQ_PASSWORD=
POSTGRES_PASSWORD=

# Local S3-compatible object store credentials (SeaweedFS).
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Default S3_PUBLIC_ENDPOINT is http://localhost:4566 and works only when the
# browser runs on the same host. For a remote browser, publish S3 through an
# authenticated/TLS edge and set S3_PUBLIC_ENDPOINT to that external URL.
S3_PUBLIC_ENDPOINT=

# Shared knowledge base: every signed-in user searches the whole corpus and
# may preview any indexed document (chats/uploads stay private). Set to false
# for strict per-owner tenant isolation.
RAG_SHARED_CORPUS=true

# Interactive-vs-batch QoS. RAG_MAX_CONCURRENT bounds simultaneous RAG
# pipelines in llm-service (queue up to RAG_QUEUE_WAIT, then 503);
# INGEST_YIELD_MAX_WAIT is how long chunk-splitter yields per document while
# user queries are in flight (then it trickles — ingestion never starves).
RAG_MAX_CONCURRENT=16
RAG_QUEUE_WAIT=10s
RAG_GENERATE_TIMEOUT=150s
INGEST_YIELD_MAX_WAIT=2s
# Chunks per embed->upsert->index round-trip in chunk-splitter: bounds worker
# memory and backend request sizes for very large documents.
EMBED_BATCH=64

# ---------------------------------------------------------------------------
# Neural network endpoints.
# Embeddings and OCR are wired to internal compose services by default:
# f2llm-service and paddleocr-vl-service. Override these only when using an external
# engine. Generation/VLM remain external unless VLLM_URL/VLM_ENGINE_URL are set.
# ---------------------------------------------------------------------------

# Embeddings (F2LLM-v2). Expected: POST {url}
#   req {"model":..,"input":[texts]}  resp {"data":[{"embedding":[...]}]}
EMBEDDINGS_URL=http://f2llm-service:8085/v1/embeddings
EMBEDDINGS_MODEL=codefuse-ai/F2LLM-v2-0.6B
# Must match what the model outputs. Writer & reader must agree.
EMBEDDING_DIM=1024
F2LLM_MODEL=codefuse-ai/F2LLM-v2-0.6B
F2LLM_MAX_TOKENS=512
F2LLM_TORCH_DEVICE=cuda

# Generation (OpenAI-compatible engine). Calls {url}/v1/chat/completions —
# base URL БЕЗ /v1. Empty VLLM_URL = generation stub.
# Полностью локальный вариант (llama.cpp, профиль local-llm в compose):
#   docker compose -f infra/docker-compose.yml --profile local-llm up -d llama-server
# VLLM_URL=http://llama-server:8090
# VLLM_API_KEY=
# LLAMA_GGUF_DIR=../models/gguf
# LLAMA_GGUF_MODEL=Qwen3-30B-A3B-Q4_K_M.gguf
# Yandex AI Studio, OpenAI-совместимый контур организаторов.
# Модель задаётся URI вида gpt://<folder_id>/<model>/latest.
# Список доступных моделей можно проверить через scripts/check-llm.sh после
# заполнения VLLM_API_KEY.
# VLLM_URL=https://llm.api.cloud.yandex.net
# VLLM_API_KEY=<Api-Key от организаторов>
# VLLM_MODEL=gpt://<folder_id>/deepseek-v4-flash/latest
VLLM_URL=
VLLM_API_KEY=
VLLM_MODEL=qwen3-35b-a3b
# Мягкий клиентский темп (запросов/мин на инстанс; 0 = без троттлинга).
# Yandex AI Studio: RPM-квот нет. Есть лимит на одновременные генерации.
# Значение 60 сглаживает всплески запросов на одном инстансе.
VLLM_RPM=60
# Лимиты для шкалы «Запросы сегодня» на дашборде метрик.
# 0 означает, что лимита нет и шкала скрывается.
LLM_DAILY_LIMIT=0
LLM_PER_MIN_LIMIT=0

# Учёт затрат LLM на дашборде «Метрики». Провайдеры без usage.cost в ответе
# (например, Yandex AI Studio) оцениваются по прайсу: цена за 1 млн токенов в
# валюте провайдера. Значения — из актуального прайса Yandex Cloud
# (https://yandex.cloud/ru/docs/ai-studio/pricing), цены не выдумывать.
# По-модельная таблица цен (подстрока имени = вход/выход за 1M; первый матч
# побеждает; явный 0/0 — известно-бесплатная модель). Пара LLM_PRICE_*_PER_1M
# ниже — фолбэк для моделей вне списка.
# LLM_PRICES="deepseek-v4-flash=300/500;qwen3.6=500/500;:free=0/0"
# LLM_PRICE_PROMPT_PER_1M=<цена 1 млн входных токенов, см. прайс Yandex Cloud>
# LLM_PRICE_COMPLETION_PER_1M=<цена 1 млн выходных токенов, см. прайс Yandex Cloud>
# LLM_COST_CURRENCY=₽
# Общий бюджет в валюте провайдера — на дашборде остаток = бюджет − расход.
# LLM_BUDGET_TOTAL=<сумма бюджета>

# Materials Project API key (https://next-gen.materialsproject.org/api) for
# computed novelty / prior-art sanity checks. Empty = the MP client is a safe stub.
MP_API_KEY=

# Публикации для блока «мировая практика» (OpenAlex + Crossref). OpenAlex требует
# mailto (polite pool): пустой PUBSEARCH_MAILTO — источник пропускается, работает
# только Crossref. PUBSEARCH_ENABLED=false выключает поиск целиком.
# VLLM_URL/MODEL/API_KEY, PUBSEARCH_*, RAG_GEN_BREADTH,
# RAG_GEN_QUALITY_FLOOR и KPI_SUGGEST переопределяются в рантайме без редеплоя:
# админ-панель «Настройки» → «Параметры платформы» (оверрайды в Postgres,
# раздаются сервисам через Valkey).
PUBSEARCH_MAILTO=
PUBSEARCH_ENABLED=true

# Reranker (Qwen3-Reranker). Expected: POST {url}
#   req {"model":..,"query":..,"documents":[..]}
#   resp {"scores":[..],"results":[{index,relevance_score}]}
RERANKER_URL=http://reranker-service:8086/v1/rerank
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANKER_SERVICE_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANKER_TORCH_DEVICE=cuda
RERANKER_MAX_TOKENS=4096
RERANKER_BATCH=8

# OCR (PaddleOCR-VL). Expected: POST {url}
#   req {"model":..,"image_b64":..,"mime":..}  resp {"text":..}
OCR_ENGINE_URL=http://paddleocr-vl-service:8088
OCR_MODEL=PaddleOCR-VL

# Workbook parser for XLSX/XLSM/XLTX/XLTM. Empty WORKBOOK_PARSER_URL disables
# structured parsing and falls back to legacy flat text extraction in office-parser.
WORKBOOK_PARSER_URL=http://workbook-parser-service:8095
WORKBOOK_MAX_UPLOAD_MB=128
WORKBOOK_PARSER_LOG_LEVEL=info

# Куда роутить загруженные изображения: ocr (локальный OCR) или vlm
# (Yandex Qwen3.6 / мультимодальное описание схем и сканов — см. VLM_* ниже).
IMAGE_PARSE_ROUTE=ocr

# Vision-language (Qwen-VL). Native protocol: POST {url}
#   req {"model":..,"image_b64":..,"mime":..,"prompt":..}  resp {"text":..}
# VLM_API_STYLE=openai switches to OpenAI vision chat/completions: base URL
# without /v1, image as data-URI image_url, VLM_API_KEY as Bearer.
# Yandex AI Studio для ключей организаторов:
# VLM_ENGINE_URL=https://llm.api.cloud.yandex.net
# VLM_MODEL=gpt://<folder-id>/qwen3.6-35b-a3b/latest
# VLM_API_STYLE=openai
# VLM_API_KEY=<Api-Key от организаторов>
# IMAGE_PARSE_ROUTE=vlm
VLM_ENGINE_URL=
VLM_MODEL=qwen3.5-9b
VLM_API_STYLE=native
VLM_API_KEY=

# Local non-LLM diagram parser for technological schemes. It uses OpenCV for
# block/connector extraction. The default service keeps the previous
# PaddleOCR-VL flow.
# Enable the existing flow with:
#   IMAGE_PARSE_ROUTE=vlm
#   VLM_ENGINE_URL=http://diagram-parser-service:8089
#   VLM_MODEL=diagram-opencv-paddle
#   docker compose --profile diagram-parser up -d diagram-parser-service vlm-service
# Enable local GPU PP-OCRv5 labels with:
#   IMAGE_PARSE_ROUTE=vlm
#   VLM_ENGINE_URL=http://diagram-parser-paddle5-service:8089
#   VLM_MODEL=diagram-opencv-paddle
#   docker compose --profile diagram-parser-paddle5 up -d diagram-parser-paddle5-service vlm-service
# Modes full-image/tiles4/tiles9 call DIAGRAM_OCR_URL and require the
# paddleocr-vl-service container. The paddle5 service does not call DIAGRAM_OCR_URL.
DIAGRAM_OCR_URL=http://paddleocr-vl-service:8088
DIAGRAM_OCR_MODEL=PaddleOCR-VL
DIAGRAM_OCR_TIMEOUT=90
DIAGRAM_OCR_MODE=full-image
DIAGRAM_PADDLE5_LANG=ru
DIAGRAM_PADDLE5_DEVICE=gpu
DIAGRAM_PADDLE5_DET_MODEL=PP-OCRv5_server_det
DIAGRAM_PADDLE5_REC_MODEL=eslav_PP-OCRv5_mobile_rec
DIAGRAM_PADDLE5_REC_BATCH_SIZE=8
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
DIAGRAM_BLOCK_OCR_MAX_BLOCKS=12
DIAGRAM_TILE_OCR_TIMEOUT=45
DIAGRAM_TILE_OVERLAP_PX=32
DIAGRAM_PARSE_CONCURRENCY=1
DIAGRAM_FAIL_OPEN=false

# Background jobs.
CLUSTER_CHECK_INTERVAL=15
CLUSTER_DEBOUNCE_SEC=45
# Clustering tunables (see cluster-worker/README.md).
CLUSTER_KNN_K=6
CLUSTER_KNN_BLOCK_SIZE=512
CLUSTER_RESOLUTION=1.0
CLUSTER_MIN_SIZE=2
# Drop graph edges below this cosine similarity (0.0 keeps every mutual-kNN pair).
CLUSTER_SIM_THRESHOLD=0.0
# true = mutual kNN (tight themes); false = union kNN (denser graph, larger clusters).
CLUSTER_MUTUAL_KNN=true
LAST_CLUSTERED_KEY=rag:clusters:last_epoch
AUTO_HYPOTHESES=true
AUTO_HYPOTHESIS_LIMIT=24
ITC_TRIGGER_KEY=rag:itc:trigger
# Scheduled RAG evaluation spends generation/judge calls. Keep it off in the
# shipped example; admins can still trigger a run from the metrics page.
EVAL_INTERVAL_SEC=0
EVAL_STARTUP_DELAY_SEC=120
EVAL_CHECK_INTERVAL_SEC=10
EVAL_HYPOTHESES=0
EVAL_DISCOVERY=1
ITC_INTERVAL_SEC=3600
ITC_STARTUP_DELAY_SEC=180
