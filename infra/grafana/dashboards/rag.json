{
  "uid": "rag-pipeline",
  "title": "RAG Pipeline",
  "tags": ["rag"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Messages processed / sec (by queue & outcome)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue, outcome) (rate(rag_messages_processed_total[5m]))",
          "legendFormat": "{{queue}} {{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Processing latency p95 (s) by queue",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, queue) (rate(rag_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Indexed messages (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(rag_messages_processed_total{queue=\"chunk\",outcome=\"ok\"}[24h]))",
          "legendFormat": "indexed"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Dead-lettered (errors) / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (rate(rag_messages_processed_total{outcome=\"error\"}[5m]))",
          "legendFormat": "{{queue}}"
        }
      ]
    }
  ]
}
